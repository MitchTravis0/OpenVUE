# OpenVUE Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Required
# ===================

# Anthropic API key for Claude Computer Use
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================
# Speech-to-Text (Optional)
# ===================

# STT engine to use: whisper-cpp, faster-whisper, vosk, whisper
STT_ENGINE=whisper-cpp

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Whisper compute device: cpu, cuda
WHISPER_DEVICE=cpu

# ===================
# Claude Computer Use (Optional)
# ===================

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Display resolution for Claude screenshots
CLAUDE_DISPLAY_WIDTH=1024
CLAUDE_DISPLAY_HEIGHT=768
